# MultiRAG Learning System - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: API Keys
# =============================================================================

# Google Gemini API Key for LLM generation
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face Token (optional, for downloading models)
# Get from: https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=your_huggingface_token_here

# =============================================================================
# Optional: Data Paths
# =============================================================================

# Workspace data storage (default: data/workspaces)
MULTIRAG_DATA_DIR=data/workspaces

# Cache storage (default: data/cache)
MULTIRAG_CACHE_DIR=data/cache

# ChromaDB persistence directory (default: data/chroma)
MULTIRAG_CHROMA_DIR=data/chroma

# =============================================================================
# Optional: Model Configuration
# =============================================================================

# Embedding model (default: sentence-transformers/all-MiniLM-L6-v2)
# Other options: sentence-transformers/all-mpnet-base-v2, intfloat/e5-base-v2
MULTIRAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Generation model (default: gemini-2.5-flash)
# Other options: gemini-2.0-flash, gemini-1.5-flash
MULTIRAG_GENERATION_MODEL=gemini-2.5-flash

# =============================================================================
# Optional: Chunking Configuration
# =============================================================================

# Target chunk size in characters (default: 512)
MULTIRAG_CHUNK_SIZE=512

# Overlap between chunks in characters (default: 64)
MULTIRAG_CHUNK_OVERLAP=64

# =============================================================================
# Optional: Vector Store Selection
# =============================================================================

# Vector store type: "chroma" or "faiss" (default: chroma)
MULTIRAG_VECTOR_STORE=chroma

# =============================================================================
# Optional: Web Scraping Configuration
# =============================================================================

# URL fetch timeout in seconds (default: 10)
MULTIRAG_URL_TIMEOUT_SECONDS=10

# Max crawl pages (default: 50, set to 1 for single-page only)
MULTIRAG_MAX_CRAWL_PAGES=50

# Max concurrent workers (default: 10)
MULTIRAG_MAX_WORKERS=10

# =============================================================================
# Optional: Upload Limits
# =============================================================================

# Maximum upload size in bytes (default: 50MB)
MULTIRAG_MAX_UPLOAD_BYTES=52428800
